// src/PhysicsList.cc
// Physics list for muon-trident studies.
//
// We build it manually (rather than FTFP_BERT) to make the relevant
// processes explicit and keep the simulation fast.
//
// Included processes
// ──────────────────
//  Muons  : G4MuMultipleScattering, G4MuIonisation, G4MuBremsstrahlung,
//            **G4MuPairProduction** (tridents!), G4Decay
//  e±     : G4eMultipleScattering, G4eIonisation, G4eBremsstrahlung,
//            G4eplusAnnihilation
//  Photons: G4PhotoElectricEffect, G4ComptonScattering, G4GammaConversion

#include "PhysicsList.hh"

#include "G4LeptonConstructor.hh"
#include "G4BosonConstructor.hh"
#include "G4MesonConstructor.hh"
#include "G4BaryonConstructor.hh"
#include "G4IonConstructor.hh"
#include "G4ShortLivedConstructor.hh"
#include "G4ParticleTypes.hh"

#include "G4ProcessManager.hh"
#include "G4MuMultipleScattering.hh"
#include "G4MuIonisation.hh"
#include "G4MuBremsstrahlung.hh"
#include "G4MuPairProduction.hh"   // ← THE key process
#include "G4eMultipleScattering.hh"
#include "G4eIonisation.hh"
#include "G4eBremsstrahlung.hh"
#include "G4eplusAnnihilation.hh"
#include "G4PhotoElectricEffect.hh"
#include "G4ComptonScattering.hh"
#include "G4GammaConversion.hh"
#include "G4Decay.hh"
#include "G4VPhysicsConstructor.hh"
#include "G4SystemOfUnits.hh"
#include "G4EmParameters.hh"

// ─────────────────────────────────────────────────────────────────────────────
namespace {

void BuildAllParticles()
{
    G4LeptonConstructor{}.ConstructParticle();
    G4BosonConstructor{}.ConstructParticle();
    G4MesonConstructor{}.ConstructParticle();
    G4BaryonConstructor{}.ConstructParticle();
    G4IonConstructor{}.ConstructParticle();
    G4ShortLivedConstructor{}.ConstructParticle();
}

class ParticlePhysics : public G4VPhysicsConstructor {
public:
    ParticlePhysics() : G4VPhysicsConstructor("Particles") {}
    void ConstructParticle() override { BuildAllParticles(); }
    void ConstructProcess()  override {}
};

class EMPhysics : public G4VPhysicsConstructor {
public:
    EMPhysics() : G4VPhysicsConstructor("EM_MuTrident") {}
    void ConstructParticle() override {}
    void ConstructProcess()  override
    {
        G4ProcessManager* pm;

        // μ-
        pm = G4MuonMinus::MuonMinus()->GetProcessManager();
        pm->AddProcess(new G4MuMultipleScattering(), -1,  1,  1);
        pm->AddProcess(new G4MuIonisation(),         -1,  2,  2);
        pm->AddProcess(new G4MuBremsstrahlung(),     -1,  3,  3);
        pm->AddProcess(new G4MuPairProduction(),     -1,  4,  4);  // tridents!
        pm->AddProcess(new G4Decay(),                 1, -1,  5);

        // μ+
        pm = G4MuonPlus::MuonPlus()->GetProcessManager();
        pm->AddProcess(new G4MuMultipleScattering(), -1,  1,  1);
        pm->AddProcess(new G4MuIonisation(),         -1,  2,  2);
        pm->AddProcess(new G4MuBremsstrahlung(),     -1,  3,  3);
        pm->AddProcess(new G4MuPairProduction(),     -1,  4,  4);  // tridents!
        pm->AddProcess(new G4Decay(),                 1, -1,  5);

        // e-
        pm = G4Electron::Electron()->GetProcessManager();
        pm->AddProcess(new G4eMultipleScattering(), -1, 1, 1);
        pm->AddProcess(new G4eIonisation(),         -1, 2, 2);
        pm->AddProcess(new G4eBremsstrahlung(),     -1, 3, 3);

        // e+
        pm = G4Positron::Positron()->GetProcessManager();
        pm->AddProcess(new G4eMultipleScattering(), -1,  1, 1);
        pm->AddProcess(new G4eIonisation(),         -1,  2, 2);
        pm->AddProcess(new G4eBremsstrahlung(),     -1,  3, 3);
        pm->AddProcess(new G4eplusAnnihilation(),    0, -1, 4);

        // γ
        pm = G4Gamma::Gamma()->GetProcessManager();
        pm->AddDiscreteProcess(new G4PhotoElectricEffect());
        pm->AddDiscreteProcess(new G4ComptonScattering());
        pm->AddDiscreteProcess(new G4GammaConversion());
    }
};

} // anonymous namespace

// ─────────────────────────────────────────────────────────────────────────────
PhysicsList::PhysicsList()
{
    defaultCutValue = 1.0 * mm;
    SetVerboseLevel(1);
    G4EmParameters::Instance()->SetDefaults();
    RegisterPhysics(new ParticlePhysics());
    RegisterPhysics(new EMPhysics());
}

void PhysicsList::SetCuts()
{
    SetCutsWithDefault();
    SetCutValue(0.1 * mm, "e-");
    SetCutValue(0.1 * mm, "e+");
    SetCutValue(0.1 * mm, "gamma");
    SetCutValue(1.0 * mm, "mu-");
    SetCutValue(1.0 * mm, "mu+");
}
